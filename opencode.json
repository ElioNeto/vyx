{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "shell": "/bin/bash",
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_TOKEN": "{env:GH_TOKEN}"
      },
      "enabled": true
    }
  }
}
