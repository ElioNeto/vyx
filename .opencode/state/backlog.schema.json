{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Backlog State",
  "type": "object",
  "required": ["last_sync", "issues"],
  "properties": {
    "last_sync": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp da última sincronização com o GitHub"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "title", "priority", "status"],
        "properties": {
          "number": { "type": "integer" },
          "title": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "status": { "type": "string", "enum": ["open", "done", "blocked"] },
          "depends_on": { "type": "array", "items": { "type": "integer" } },
          "blocks": { "type": "array", "items": { "type": "integer" } },
          "acceptance_summary": { "type": "array", "items": { "type": "string" }, "maxItems": 5 },
          "fetched_body": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
