{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "webfetch": "allow",
    "question": "deny",
    "external_directory": "ask",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "git push *": "ask",
      "git commit *": "ask"
    }
  },
  "mcp": {
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e", "SONARQUBE_TOKEN",
        "-e", "SONARQUBE_URL",
        "-e", "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "${SONAR_TOKEN}",
        "SONARQUBE_URL": "https://sonarcloud.io",
        "SONARQUBE_ORG": "elioneto"
      },
      "enabled": true
    }
  }
}
